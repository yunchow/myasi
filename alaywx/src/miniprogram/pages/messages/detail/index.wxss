page {
  background-color: #000000;
  color: #FFFFFF;
}

.container {
  padding: 16px;
  display: flex;
  flex-direction: column;
}

.article-card {
  margin-bottom: 32px;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 17px;
  font-weight: 500;
  color: #FFFFFF;
  line-height: 1.4;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Multi-image layout */
.image-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 8px;
}

.thumb-small {
  width: 32%; /* 3 items with gap */
  height: 80px; /* Fixed height for consistency */
  border-radius: 4px;
  background-color: #2C2C2E;
}

/* Single large image layout */
.thumb-large {
  width: 100%;
  height: 160px;
  border-radius: 4px;
  background-color: #2C2C2E;
  margin-bottom: 8px;
}

/* Footer */
.card-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 4px;
}

.source-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.tag-blue {
  font-size: 11px;
  color: #0A84FF;
  margin-right: 6px;
  font-weight: 500;
}

.source-name {
  font-size: 12px;
  color: #8E8E93;
}

.action-btn {
  width: 16px;
  height: 16px;
  border: 1px solid #3A3A3C;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn-text {
  font-size: 10px;
  color: #8E8E93;
  line-height: 1;
  position: relative;
  top: -1px; /* Visual alignment */
}

.empty-state {
  padding: 50px 0;
  text-align: center;
}

.empty-text {
  color: #8E8E93;
  font-size: 14px;
}
