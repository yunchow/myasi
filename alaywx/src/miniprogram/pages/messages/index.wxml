<view class="container">
  <scroll-view scroll-y class="list" refresher-enabled="{{true}}" refresher-default-style="white" refresher-background="#000000" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <block wx:for="{{conversations}}" wx:key="id">
      <view class="conversation-item" hover-class="item-hover" bindtap="onTapConversation" data-name="{{item.name}}">
        <view class="avatar-container">
          <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:if="{{item.unreadCount > 0}}" class="badge-dot"></view>
        </view>
        
        <view class="content">
          <view class="top-row">
            <text class="title">{{item.name}}</text>
            <text class="time">{{item.timeStr}}</text>
          </view>
          
          <view class="bottom-row">
            <text class="preview">{{item.preview}}</text>
          </view>
        </view>
      </view>
    </block>
    
    <view wx:if="{{conversations.length === 0}}" class="empty-state">
      <text class="empty-text">掌握关键消息，不错过关键行情</text>
    </view>
  </scroll-view>
</view>
