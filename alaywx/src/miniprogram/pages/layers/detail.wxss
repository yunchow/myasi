page {
  background-color: #000000;
}

.header-section {
  padding: 16px;
  background-color: #000000;
  z-index: 10;
}

.layer-header-card {
  background: linear-gradient(135deg, #1C1C1E 0%, #2C2C2E 100%);
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}

.layer-title-large {
  font-size: 22px;
  font-weight: 700;
  color: #FFFFFF;
}

.badge {
  background-color: rgba(255,255,255,0.1);
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 11px;
  color: #C8C8C8;
}

.label-light {
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  margin-bottom: 4px;
}

.amount-large {
  font-size: 28px;
  font-weight: 700;
  color: #FFFFFF;
}

.amount-medium {
  font-size: 20px;
  font-weight: 700;
}

.action-bar {
  display: flex;
  flex-direction: row;
}

.btn-glass {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
}

.flex-1 { flex: 1; }
.mr-8 { margin-right: 8px; }
.ml-8 { margin-left: 8px; }
.mt-16 { margin-top: 16px; }
.mt-4 { margin-top: 4px; }
.ml-12 { margin-left: 12px; }
.items-end { align-items: flex-end; }

.list-section {
  flex: 1;
  padding: 0 16px;
}

.position-card {
  background-color: #1C1C1E;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
}

.icon-placeholder {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background-color: #2C2C2E;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #8E8E93;
  font-size: 18px;
}

.divider-subtle {
  height: 1px;
  background-color: #2C2C2E;
  margin: 12px 0;
}

.empty-state {
  padding: 40px 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  color: #636366;
  font-size: 14px;
}
