.container {
  padding: 16px;
  padding-bottom: 40px;
}

.section-header {
  margin-bottom: 12px;
  padding-left: 4px;
}

.chips-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.chip {
  padding: 6px 12px;
  border-radius: 16px;
  background-color: #2C2C2E;
  color: var(--text-secondary);
  font-size: 14px;
  border: 1px solid transparent;
}

.chip-selected {
  color: var(--text-main);
  font-weight: 600;
}

.chip-add {
  background-color: transparent;
  border: 1px dashed #636366;
  color: #636366;
}

.form-card {
  background-color: var(--card-bg);
  border-radius: 12px;
  padding: 0 16px;
}

.list-card {
  background-color: var(--card-bg);
  border-radius: 12px;
  padding: 0 16px;
}

.input-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 52px;
}

.label {
  font-size: 16px;
  color: var(--text-main);
  min-width: 80px;
}

.input-clean {
  text-align: right;
  color: var(--text-main);
  font-size: 16px;
  flex: 1;
}

.ph {
  color: var(--text-muted);
}

.divider {
  height: 1px;
  background-color: rgba(255, 255, 255, 0.1);
}

.h-scroll {
  white-space: nowrap;
  height: 36px;
}

.chip-small {
  display: inline-block;
  padding: 6px 12px;
  background-color: #2C2C2E;
  border-radius: 14px;
  font-size: 13px;
  color: var(--text-secondary);
}

.chip-small.active {
  background-color: var(--primary-color);
  color: white;
}

.actions-area {
  margin-top: 32px;
}

.w-full { width: 100%; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mb-8 { margin-bottom: 8px; }

.btn-small {
  padding: 4px 12px;
  background-color: rgba(10, 132, 255, 0.2);
  color: var(--primary-color);
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.1);
}
.list-item:last-child {
  border-bottom: none;
}

.empty-hint {
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
  padding: 20px;
}
