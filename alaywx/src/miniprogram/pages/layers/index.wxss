
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.content {
  flex: 1;
  height: 100%;
}

.header-section {
  padding: 16px;
  padding-bottom: 8px;
}

.overview-card {
  background: linear-gradient(145deg, #1C1C1E 0%, #2C2C2E 100%);
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
}

.label {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.total-amount {
  font-size: 36px;
  font-weight: 700;
  color: var(--text-main);
  margin: 8px 0 16px 0;
  letter-spacing: 0.5px;
}

.badge {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 10px;
  color: var(--text-secondary);
}

.divider {
  height: 1px;
  background-color: rgba(255, 255, 255, 0.1);
  margin-bottom: 16px;
}

.value {
  font-size: 18px;
  font-weight: 600;
}

/* Light Card Theme Overrides */
.overview-card.light-card .label {
  color: #8E8E93;
}
.overview-card.light-card .total-amount {
  color: #000000;
}
.overview-card.light-card .badge {
  background-color: rgba(0, 0, 0, 0.05);
  color: #8E8E93;
}
.overview-card.light-card .divider {
  background-color: rgba(0, 0, 0, 0.05);
}
.overview-card.light-card .text-positive {
  color: #34C759;
}
.overview-card.light-card .text-negative {
  color: #FF3B30;
}

.layers-section {
  padding: 16px;
}

.section-header {
  margin-bottom: 16px;
  padding: 0 4px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-main);
}

/* Enhanced Add Button */
.icon-btn-add {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 32px;
  color: var(--primary-color);
  font-weight: 400;
  line-height: 32px;
  margin-top: -2px; /* Visual adjustment */
}

.layer-card {
  background-color: var(--card-bg);
  border-radius: 16px;
  margin-bottom: 16px;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: row;
}

.layer-color-strip {
  width: 6px;
  height: 100%;
}

.layer-content {
  flex: 1;
  padding: 16px;
}

.layer-name {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-main);
}

.layer-asset {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-main);
}

.mb-8 {
  margin-bottom: 8px;
}

.tags {
  display: flex;
  gap: 8px;
}

.tag {
  background-color: rgba(255, 255, 255, 0.08);
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 12px;
  color: var(--text-secondary);
}

.layer-pnl {
  font-size: 14px;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-main);
  margin-top: 16px;
}

.empty-desc {
  font-size: 14px;
  color: var(--text-secondary);
  margin-top: 8px;
}

.mt-16 {
  margin-top: 24px;
}
