page {
  background-color: #000000;
  color: #FFFFFF;
}

.container {
  padding: 16px;
  height: 100vh;
}

.profile-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 28px;
  margin-top: 20px;
}

.avatar-wrapper {
  width: 60px;
  height: 60px;
  border-radius: 30px;
  background-color: #2C2C2E;
  margin-right: 16px;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
  display: block;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 20px;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4px;
}

.user-id {
  font-size: 14px;
  color: #8E8E93;
}

.group-title {
  color: rgba(235, 235, 245, 0.6);
  font-size: 13px;
  margin-bottom: 8px;
  margin-left: 10px;
}

.group {
  background-color: #1C1C1E;
  border-radius: 14px;
  overflow: hidden;
}

.row {
  padding: 14px;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.10);
}

.row.last {
  border-bottom: none;
}

.label {
  font-size: 16px;
  font-weight: 700;
  color: #FFFFFF;
}

.arrow {
  color: #8E8E93;
  font-size: 16px;
}
