.container {
  padding: 20px;
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.title {
  font-size: 20px;
  font-weight: bold;
}

.add-btn {
  font-size: 14px;
  color: #007AFF;
  padding: 5px 10px;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 15px;
}

.list {
  flex: 1;
  overflow-y: auto;
}

.item {
  display: flex;
  align-items: center;
  padding: 15px 0;
  border-bottom: 1px solid #eee;
}

.content {
  flex: 1;
}

.name {
  font-size: 16px;
  font-weight: 500;
  margin-right: 10px;
}

.priority {
  font-size: 12px;
  color: #8E8E93;
}

.actions {
  display: flex;
}

.action-btn {
  font-size: 14px;
  margin-left: 15px;
}

.edit {
  color: #007AFF;
}

.delete {
  color: #FF3B30;
}

.empty {
  text-align: center;
  margin-top: 50px;
  color: #999;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.modal {
  width: 80%;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.modal-header {
  padding: 15px;
  text-align: center;
  font-weight: bold;
  border-bottom: 1px solid #eee;
}

.modal-content {
  padding: 20px;
}

.form-item {
  margin-bottom: 15px;
}

.label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 5px;
}

.input {
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 8px;
  font-size: 14px;
}

.modal-footer {
  display: flex;
  border-top: 1px solid #eee;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 15px 0;
  font-size: 16px;
}

.cancel {
  color: #666;
  border-right: 1px solid #eee;
}

.save {
  color: #007AFF;
  font-weight: bold;
}
