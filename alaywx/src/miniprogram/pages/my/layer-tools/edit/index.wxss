/* 深色模式风格 */
page {
  background-color: #000;
  color: #fff;
}

.container {
  padding: 20px;
}

.form-group {
  margin-bottom: 20px;
  background-color: #1C1C1E;
  border-radius: 12px;
  overflow: hidden;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #2C2C2E;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 16px;
  color: #fff;
  width: 100px;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 16px;
  color: #8E8E93;
}

.picker-value {
  font-size: 16px;
  color: #8E8E93;
}

.btn-area {
  margin-top: 30px;
}

.btn-save {
  background-color: #0A84FF;
  color: #fff;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 500;
  padding: 12px;
}
