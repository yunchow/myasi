{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2017", "dom"],
    "allowJs": false,
    "checkJs": false,
    "noEmit": false,
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "types": ["miniprogram-api-typings"],
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/miniprogram-api-typings/types"
    ]
  },
  "include": ["./**/*.ts", "./**/*.js"],
  "exclude": ["node_modules"]
}
