/**app.wxss**/
page {
  --bg-color: #000000;
  --card-bg: #1C1C1E;
  --text-main: #FFFFFF;
  --text-secondary: #C8C8C8; /* Improved contrast */
  --text-muted: #8E8E93;
  --primary-color: #0A84FF;
  --success-color: #5ACF9A; /* Less neon green */
  --danger-color: #FF453A; /* iOS Red */
  --separator-color: #38383A;
  
  background-color: var(--bg-color);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: 16px;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Common Card Style */
.card {
  background-color: var(--card-bg);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  /* border: 1px solid var(--separator-color); Remove border for cleaner look, use subtle separator if needed */
}

/* Buttons */
.btn-primary {
  background-color: var(--primary-color);
  color: #FFFFFF;
  font-weight: 600;
  border-radius: 12px;
  padding: 12px 20px;
  text-align: center;
  font-size: 16px;
}

.btn-danger {
  background-color: rgba(255, 69, 58, 0.15);
  color: var(--danger-color);
  font-weight: 600;
  border-radius: 12px;
  padding: 12px 20px;
  text-align: center;
  font-size: 16px;
}

.btn-secondary {
  background-color: #2C2C2E;
  color: var(--text-main);
  font-weight: 600;
  border-radius: 12px;
  padding: 12px 20px;
  text-align: center;
  font-size: 16px;
}

/* Typography */
.text-l { font-size: 18px; font-weight: 700; }
.text-m { font-size: 16px; font-weight: 600; }
.text-s { font-size: 14px; color: var(--text-secondary); }
.text-xs { font-size: 12px; color: var(--text-muted); }

.text-positive { color: var(--success-color); }
.text-negative { color: var(--danger-color); }

/* Flex Helpers */
.row { display: flex; flex-direction: row; align-items: center; }
.col { display: flex; flex-direction: column; }
.center { align-items: center; justify-content: center; }
.between { justify-content: space-between; }
.gap-s { gap: 8px; }
.gap-m { gap: 12px; }

/* Inputs */
.input-field {
  background-color: #2C2C2E;
  border-radius: 12px;
  padding: 12px;
  color: white;
  font-size: 16px;
  margin-bottom: 12px;
}
.input-placeholder {
  color: #636366;
}

/* List Items */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 0.5px solid var(--separator-color);
}
.list-item:last-child {
  border-bottom: none;
}
